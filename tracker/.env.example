PORT=3001

# Meta CAPI — required for Meta event forwarding
META_PIXEL_ID=your_pixel_id_here
META_ACCESS_TOKEN=your_access_token_here
META_TEST_EVENT_CODE=        # optional — set to TEST... string to use Meta's test event tool

# ClickHouse — required for event storage (Docker or hosted)
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
